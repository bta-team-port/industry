{
  "schemaVersion": 1,
  "id": "industry",
  "version": "${version}",

  "name": "Industry",
  "description": "A retake of IC2 and Buildcraft for BTA!",
  "authors": [
    "Cookie Cakes"
  ],
  "contributors": [
    "TeamPort"
  ],
  "contact": {
    "homepage": "https://github.com/bta-team-port",
    "sources": "https://github.com/FatherCheese/industry",
    "issues": "https://github.com/FatherCheese/industry/issues"
  },

  "license": "CC0-1.0",
  "icon": "icon.png",

  "environment": "*",
  "entrypoints": {
    "main": [
      "teamport.industry.Industry"
    ],
    "afterBlockInit": [
      "teamport.industry.core.block.IndBlocks"
    ],
    "afterItemInit": [
      "teamport.industry.core.item.IndItems"
    ],
    "afterGameStart": [
      "teamport.industry.Industry"
    ],
    "beforeGameStart": [
      "teamport.industry.Industry"
    ],
    "client": [
      "teamport.industry.IndustryClient"
    ],
    "afterClientStart": [
      "teamport.industry.IndustryClient"
    ],
    "beforeClientStart": [
      "teamport.industry.IndustryClient"
    ],
    "initModels": [
      "teamport.industry.client.model.IndModels"
    ],
    "server": [
      "teamport.industry.IndustryServer"
    ],
    "recipesReady": [
      "teamport.industry.core.recipe.IndRecipes"
    ]
  },
  "mixins": [
    "industry.mixins.json"
  ],

  "accessWidener": "industry.accesswidener",

  "depends": {
    "minecraft": "^7.2-beta",
    "fabricloader": ">=0.15.5",
    "halplibe":">=5.2.3"
  },
  "suggests": {
  }
}